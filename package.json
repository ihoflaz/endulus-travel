{
  "name": "endulus-travel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail=100",
    "docker:logs:backend": "docker compose logs -f --tail=200 backend",
    "docker:logs:frontend": "docker compose logs -f --tail=200 frontend",
    "docker:rebuild": "docker compose up -d --build --force-recreate",
    "docker:reset": "docker compose down -v && docker compose up -d --build",
    "docker:ps": "docker compose ps",
    "docker:psql": "docker compose exec postgres psql -U endulus -d endulus",
    "docker:shell:backend": "docker compose exec backend sh",
    "docker:shell:postgres": "docker compose exec postgres sh"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.6",
    "i18next": "^25.1.2",
    "i18next-browser-languagedetector": "^8.1.0",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^7.6.0",
    "tailwindcss": "^4.1.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.5",
    "vite-plugin-static-copy": "^3.0.0"
  }
}
