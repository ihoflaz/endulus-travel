# Backend server config

# Postgres (used by Prisma)
DATABASE_URL="postgresql://endulus:endulus@postgres:5432/endulus?schema=public"

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change-me-access-32-bytes-min-please-rotate
JWT_REFRESH_SECRET=change-me-refresh-32-bytes-min-please-rotate
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Initial admin (used by `npm run create-admin` and seed)
ADMIN_EMAIL=admin@endulustravel.com
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Admin

# Uploads
UPLOAD_DIR=/app/uploads
PUBLIC_UPLOAD_BASE=/uploads
MAX_UPLOAD_BYTES=10485760
