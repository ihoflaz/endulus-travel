{
  "name": "endulus-travel-server",
  "version": "1.0.0",
  "description": "Backend API for Endulus Travel admin panel and public site",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "create-admin": "node scripts/create-admin.js",
    "test": "node --test --test-reporter=spec tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test --test-reporter=spec tests/unit/*.test.js",
    "test:integration": "node --test --test-reporter=spec tests/integration/*.test.js",
    "env:check": "node scripts/check-env.js",
    "cleanup": "node scripts/cleanup.js"
  },
  "dependencies": {
    "@node-rs/bcrypt": "^1.10.7",
    "@prisma/client": "^6.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^19.6.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "supertest": "^7.0.0"
  }
}
