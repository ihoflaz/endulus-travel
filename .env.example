# Copy to .env and customize. Used by docker compose.

# --- Postgres ---
# Password is interpolated into DATABASE_URL. Use ONLY URL-safe chars
# (alphanumeric, -, _, .). Generate with: openssl rand -hex 24
POSTGRES_USER=endulus
POSTGRES_PASSWORD=__REQUIRED__set_a_url_safe_password__
POSTGRES_DB=endulus
# Local: use 5433/5434 if host already has Postgres on 5432
POSTGRES_PORT=5432
POSTGRES_BIND=127.0.0.1

# --- App ---
NODE_ENV=production
BACKEND_PORT=4000
BACKEND_BIND=127.0.0.1
FRONTEND_PORT=8080
FRONTEND_BIND=127.0.0.1
# Production: replace with your real domains
CORS_ORIGIN=https://endulustravel.com,https://www.endulustravel.com

# --- JWT (use openssl rand -hex 32 to generate) ---
JWT_ACCESS_SECRET=__REQUIRED__32_byte_hex_string__
JWT_REFRESH_SECRET=__REQUIRED__different_32_byte_hex__
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
COOKIE_SECRET=__optional_defaults_to_JWT_ACCESS_SECRET__

# --- Initial admin (seeded on first start; REQUIRED in production) ---
ADMIN_EMAIL=admin@endulustravel.com
ADMIN_PASSWORD=__REQUIRED__set_a_strong_password__
ADMIN_NAME=Admin
RUN_SEED=true

# --- Auth tuning ---
BCRYPT_ROUNDS=12
TRUST_PROXY=1
EXPOSE_ERRORS=false

# --- Uploads ---
MAX_UPLOAD_BYTES=10485760

# --- Frontend build ---
VITE_API_BASE_URL=/api

# --- Backups (only used if you run `docker compose --profile backup up -d`) ---
BACKUP_RETENTION=14

# --- SMTP (form notifications + visitor acknowledgements) ---
# Leave SMTP_HOST empty to disable mailer (forms still save, no email sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
MAIL_FROM=Endülüs Travel <info@endulustravel.com>
OPS_EMAIL=endulustravel@gmail.com

# --- Site URL (used in sitemap.xml + robots.txt) ---
SITE_URL=https://endulustravel.com

# --- Meta Pixel + Conversions API ---
# Public Pixel ID (also exposed to frontend via VITE_META_PIXEL_ID).
META_PIXEL_ID=
# Server-side CAPI: dataset id + access token (token is SERVER-ONLY, never leak)
META_DATASET_ID=
META_CAPI_ACCESS_TOKEN=
# When set, CAPI events go to the Test Events panel; leave empty for live.
META_TEST_EVENT_CODE=

# --- Frontend marketing IDs (build-time, injected into JS bundle) ---
# These match the values above. Frontend reads VITE_ vars; backend reads META_.
VITE_META_PIXEL_ID=
VITE_GTM_ID=
VITE_GA4_ID=
VITE_META_IG_USERNAME=endulustravell
# Set true to mirror Pixel events to /api/meta-capi server-side.
VITE_META_CAPI_ENABLED=true
