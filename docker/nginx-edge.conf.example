# Production bare-metal nginx config for Endülüs Travel.
# Copy this to /etc/nginx/sites-available/endulustravel and `nginx -s reload`.
#
# Expected layout:
#   /etc/nginx/snippets/security-headers.conf  (created from the block below)
#   /etc/nginx/snippets/ssl-mozilla-intermediate.conf  (TLS params)
#   /etc/letsencrypt/live/endulustravel.com/{fullchain,privkey,chain}.pem
#
# Docker stack must be reachable on:
#   frontend  -> 127.0.0.1:8080
#   backend   -> 127.0.0.1:4000

# ---------------------------------------------------------------------------
# Snippet: /etc/nginx/snippets/security-headers.conf
# ---------------------------------------------------------------------------
# add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
# add_header X-Content-Type-Options "nosniff" always;
# add_header X-Frame-Options "DENY" always;
# add_header Referrer-Policy "strict-origin-when-cross-origin" always;
# add_header Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()" always;
# add_header Cross-Origin-Opener-Policy "same-origin" always;
# CSP is set on the backend via helmet — don't double-set it here.

# ---------------------------------------------------------------------------
# Snippet: /etc/nginx/snippets/ssl-mozilla-intermediate.conf
# ---------------------------------------------------------------------------
# ssl_protocols TLSv1.2 TLSv1.3;
# ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
# ssl_prefer_server_ciphers off;
# ssl_session_cache shared:SSL:10m;
# ssl_session_timeout 1d;
# ssl_session_tickets off;
# ssl_stapling on;
# ssl_stapling_verify on;
# resolver 1.1.1.1 1.0.0.1 valid=300s;
# resolver_timeout 5s;

# ---------------------------------------------------------------------------
# Rate-limit zone — 5 login attempts per minute per IP
# (place this at the top of nginx.conf http{} block)
# ---------------------------------------------------------------------------
# limit_req_zone $binary_remote_addr zone=login:10m  rate=5r/m;
# limit_req_zone $binary_remote_addr zone=api:10m    rate=30r/s;

upstream endulus_frontend { server 127.0.0.1:8080; keepalive 16; }
upstream endulus_backend  { server 127.0.0.1:4000; keepalive 16; }

# Redirect plain HTTP to HTTPS (Certbot challenges still served on :80)
server {
    listen 80;
    listen [::]:80;
    server_name endulustravel.com www.endulustravel.com;

    location /.well-known/acme-challenge/ { root /var/www/letsencrypt; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name endulustravel.com www.endulustravel.com;

    # ssl_certificate     /etc/letsencrypt/live/endulustravel.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/endulustravel.com/privkey.pem;
    # ssl_trusted_certificate /etc/letsencrypt/live/endulustravel.com/chain.pem;
    # include /etc/nginx/snippets/ssl-mozilla-intermediate.conf;
    # include /etc/nginx/snippets/security-headers.conf;

    client_max_body_size 20m;

    # gzip is enabled in the frontend container too; this is the outer layer.
    gzip on;
    gzip_vary on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    gzip_min_length 1024;

    # If you have the brotli module installed:
    # brotli on;
    # brotli_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;
    # brotli_comp_level 6;

    # ----- API -----
    location /api/auth/ {
        # limit_req zone=login burst=10 nodelay;
        proxy_pass http://endulus_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /api/ {
        # limit_req zone=api burst=60 nodelay;
        proxy_pass http://endulus_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ----- Dynamic JSON for the public site -----
    location /data/ {
        proxy_pass http://endulus_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ----- Uploaded media -----
    location /uploads/ {
        proxy_pass http://endulus_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        expires 7d;
        add_header Cache-Control "public, max-age=604800";
    }

    # ----- SPA / static frontend -----
    location / {
        proxy_pass http://endulus_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
